            "$description": "Semantic heading h5 fluid font size"
          },
          "line-height": {
            "$value": "{light.typography.heading.h5.line-height}",
            "$type": "number",
            "$description": "Semantic heading h5 line height"
          }
        },
        "h6": {
          "font-size": {
            "$value": "{light.typography.heading.h6.font-size}",
            "$type": "dimension",
            "$description": "Semantic heading h6 fluid font size"
          },
          "line-height": {
