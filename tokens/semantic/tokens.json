{
  "action": {
    "color": {
      "background": {
        "primary": {
          "$value": "{light.color.brand.primary}",
          "$type": "color",
          "$description": "Semantic primary action background color"
        }
      },
      "text": {
        "on-primary": {
          "$value": "{light.color.text.on-brand}",
          "$type": "color",
          "$description": "Semantic text color placed on primary action surfaces"
        }
      }
    },
    "space": {
      "padding": {
        "default": {
          "$value": "{light.space.button.padding.horizontal}",
          "$type": "dimension",
          "$description": "Semantic default action padding"
        }
      }
    }
  },
  "surface": {
    "color": {
      "page": {
        "$value": "{light.color.surface.canvas}",
        "$type": "color",
        "$description": "Semantic page background surface color"
      },
      "raised": {
        "$value": "{light.color.surface.raised}",
        "$type": "color",
        "$description": "Semantic elevated surface color"
      }
    }
  },
  "content": {
    "color": {
      "text": {
        "default": {
          "$value": "{light.color.text.default}",
          "$type": "color",
          "$description": "Semantic default body text color"
        },
        "muted": {
          "$value": "{light.color.text.muted}",
          "$type": "color",
          "$description": "Semantic muted body text color"
        }
      }
    },
    "typography": {
      "heading": {
        "h1": {
          "font-size": {
            "$value": "{light.typography.heading.h1.font-size}",
            "$type": "dimension",
            "$description": "Semantic heading h1 fluid font size"
          },
          "line-height": {
            "$value": "{light.typography.heading.h1.line-height}",
            "$type": "number",
            "$description": "Semantic heading h1 line height"
          }
        },
        "h2": {
          "font-size": {
            "$value": "{light.typography.heading.h2.font-size}",
            "$type": "dimension",
            "$description": "Semantic heading h2 fluid font size"
          },
          "line-height": {
            "$value": "{light.typography.heading.h2.line-height}",
            "$type": "number",
            "$description": "Semantic heading h2 line height"
          }
        },
        "h3": {
          "font-size": {
            "$value": "{light.typography.heading.h3.font-size}",
            "$type": "dimension",
            "$description": "Semantic heading h3 fluid font size"
          },
          "line-height": {
            "$value": "{light.typography.heading.h3.line-height}",
            "$type": "number",
            "$description": "Semantic heading h3 line height"
