{
  "semantic": {
    "spacing": {
      "component": {
        "button": {
          "padding": {
            "$value": "{system.spacing.component.button.padding-vertical} {system.spacing.component.button.padding-horizontal}",
            "$type": "dimension",
            "$description": "Semantic button padding - inherits from system component spacing"
          },
          "gap": {
            "$value": "{system.spacing.component.button.padding-horizontal}",
            "$type": "dimension",
            "$description": "Semantic button internal element gap"
          }
        },
        "input": {
          "padding": {
            "$value": "{system.spacing.component.input.padding-vertical} {system.spacing.component.input.padding-horizontal}",
            "$type": "dimension",
            "$description": "Semantic input padding - inherits from system component spacing"
          }
        },
        "card": {
          "padding": {
            "$value": "{system.spacing.component.card.padding}",
            "$type": "dimension",
            "$description": "Semantic card padding - inherits from system component spacing"
          }
        }
      },
      "layout": {
        "section-gap": {
          "$value": "{system.spacing.layout.gap}",
          "$type": "dimension",
          "$description": "Semantic section gap - inherits from system layout gap"
        },
        "section-margin": {
          "$value": "{system.spacing.layout.margin}",
          "$type": "dimension",
          "$description": "Semantic section margin - inherits from system layout margin"
        }
      }
    }
  }
}
