{
  "light": {
    "color": {
      "brand": {
        "primary": {
          "$value": "{color.blue.500}",
          "$type": "color",
          "$description": "Brand color for the light theme"
        }
      },
      "surface": {
        "canvas": {
          "$value": "{color.neutral.50}",
          "$type": "color",
          "$description": "Light theme page canvas background"
        },
        "raised": {
          "$value": "{color.neutral.100}",
          "$type": "color",
          "$description": "Light theme raised surface background"
        }
      },
      "text": {
        "on-brand": {
          "$value": "{color.white}",
          "$type": "color",
          "$description": "Text color placed on top of the brand color"
        },
        "default": {
          "$value": "{color.neutral.900}",
          "$type": "color",
          "$description": "Default text color for light theme"
        },
        "muted": {
          "$value": "{color.neutral.500}",
          "$type": "color",
          "$description": "Muted text color for light theme"
        }
      }
    },
    "space": {
      "button": {
        "padding": {
          "horizontal": {
            "$value": "{space.scale.200}",
            "$type": "dimension",
            "$description": "Horizontal button padding"
          },
          "vertical": {
            "$value": "{space.scale.100}",
            "$type": "dimension",
            "$description": "Vertical button padding"
          }
        }
      }
    },
    "typography": {
      "heading": {
        "h1": {
          "font-size": {
            "$value": "{font.size.fluid.h1}",
            "$type": "dimension",
            "$description": "System heading h1 fluid font size"
          },
          "line-height": {
            "$value": "{font.line-height.heading.h1}",
            "$type": "number",
            "$description": "System heading h1 line height"
          }
        },
        "h2": {
          "font-size": {
            "$value": "{font.size.fluid.h2}",
            "$type": "dimension",
            "$description": "System heading h2 fluid font size"
          },
          "line-height": {
            "$value": "{font.line-height.heading.h2}",
            "$type": "number",
            "$description": "System heading h2 line height"
          }
        },
        "h3": {
          "font-size": {
            "$value": "{font.size.fluid.h3}",
            "$type": "dimension",
            "$description": "System heading h3 fluid font size"
          },
          "line-height": {
            "$value": "{font.line-height.heading.h3}",
            "$type": "number",
            "$description": "System heading h3 line height"
          }
        },
        "h4": {
          "font-size": {
            "$value": "{font.size.fluid.h4}",
            "$type": "dimension",
