{
  "button": {
    "primary": {
      "color": {
        "text": {
          "$value": "{action.color.text.on-primary}",
          "$type": "color",
          "$description": "Primary button text color"
        },
        "background": {
          "$value": "{action.color.background.primary}",
          "$type": "color",
          "$description": "Primary button background color"
        }
      },
      "space": {
        "padding": {
          "$value": "{action.space.padding.default}",
          "$type": "dimension",
          "$description": "Primary button padding"
        }
      },
      "border": {
        "radius": {
          "$value": "0.375rem",
          "$type": "dimension",
          "$description": "Primary button corner radius"
        }
      }
    }
  },
  "page": {
    "color": {
      "background": {
        "$value": "{surface.color.page}",
        "$type": "color",
        "$description": "Page background color"
      },
      "text": {
        "$value": "{content.color.text.default}",
        "$type": "color",
        "$description": "Default page text color"
      }
    }
  },
  "heading": {
    "h1": {
      "font-size": {
        "$value": "{content.typography.heading.h1.font-size}",
        "$type": "dimension",
        "$description": "Component heading h1 fluid font size"
      },
      "line-height": {
        "$value": "{content.typography.heading.h1.line-height}",
        "$type": "number",
        "$description": "Component heading h1 line height"
      }
    },
    "h2": {
      "font-size": {
        "$value": "{content.typography.heading.h2.font-size}",
        "$type": "dimension",
        "$description": "Component heading h2 fluid font size"
